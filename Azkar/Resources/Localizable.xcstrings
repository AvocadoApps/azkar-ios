    "onboarding.completion.message" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "شكرًا لك! إذا احتجت إلى أي مساعدة أو رغبت في مشاركة ملاحظاتك، فلا تتردد في التواصل معنا عبر تلغرام — نحن دائمًا هنا لمساعدتك."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Thank you! If you need any help or want to share feedback, feel free to reach out to us on Telegram — we’re always here to assist you."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Готово! Если вам нужна помощь или вы хотите поделиться обратной связью, смело обращайтесь к нам в Telegram — мы всегда рады помочь."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Teşekkürler! Yardıma ihtiyacınız olursa veya geri bildirim paylaşmak isterseniz, Telegram üzerinden bizimle iletişime geçebilirsiniz — her zaman yardımcı olmaya hazırız."
          }
        }
      }
    },
