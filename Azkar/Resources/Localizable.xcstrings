    "onboarding.transliteration.intro" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تساعدك الترجمة الصوتية على قراءة النص العربي بالحروف اللاتينية أو السيريلية."
          }
        },
        "en" : {
