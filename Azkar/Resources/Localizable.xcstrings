    "adhkar-collections.hisn.description" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "مجموعة أذكار الصباح والمساء من الكتاب الشهير \"حصن المسلم\". تُستخدم هذه المجموعة في الغالبية العظمى من تطبيقات قراءة الأذكار."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A collection of morning and evening adhkar from the well-known compilation 'Fortress of the Muslim.'\\nThis collection is used in the vast majority of adhkar reading applications."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Коллекция утренних и вечерних азкаров из известного сборника «Крепость верующего».\nДанная коллекция используется в подавляющем большинстве приложений для чтения азкаров."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ünlü \"Müminin Kalesi\" derlemesinden sabah ve akşam ezkar koleksiyonu. Bu koleksiyon, ezkar okuma uygulamalarının büyük çoğunluğunda kullanılmaktadır."
          }
        }
      }
    },
