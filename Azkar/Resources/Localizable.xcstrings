    "onboarding.reading-mode.message" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يتوفر لك وضعان للقراءة. يعرض الوضع العادي النص على شكل مقاطع، بينما يعرض الوضع الموحّد النص سطرًا بسطر."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You have two reading modes available. The normal mode displays the text as sections. The combined mode shows the text line by line."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вам доступно два режима чтения. Обычный режим отображает текст в виде секций. Совмещённый режим показывает текст строка за строкой."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "İki okuma modu mevcuttur. Normal mod metni bölümler halinde gösterir. Birleştirilmiş mod ise metni satır satır gösterir."
          }
        }
      }
    },
