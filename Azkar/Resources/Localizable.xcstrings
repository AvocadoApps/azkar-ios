    "onboarding.transliteration.types.DIN31635" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "نظام علمي صارم لتمثيل الحروف العربية باللاتينية. يعبّر عن كل حرف عربي بشكل دقيق وواضح، باستخدام العلامات الصوتية. مناسب للقراءة الأكاديمية الدقيقة."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A strict scientific system for Latinizing Arabic script. It represents each Arabic letter unambiguously using diacritics. Suitable for precise academic reading."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Строгая научная система латинизации арабского письма. Передаёт каждую букву арабского алфавита однозначно, с использованием диакритики. Подходит для точного академического чтения."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Arap yazısını Latin alfabesine aktarmanın katı bilimsel sistemi. Her Arap harfini diakritik işaretlerle kesin biçimde iletir. Kesin akademik okuma için uygundur."
          }
        }
      }
    },
    "onboarding.welcome.message" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اسمح لي أن أقدّم لك دليلاً مختصراً لإعداد ميزات التطبيق.\n\nسيساعدك ذلك على ضبط التطبيق لاستخدام أكثر سهولة."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Let me show you a brief guide to configuring the app’s features.\n\nThis will help you set it up for more convenient use."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Позвольте мне представить вам небольшой гайд по настройке функций приложения.\n\nЭто позволит вам настроить приложение для более удобного пользования."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uygulamanın özelliklerini ayarlamanız için size kısa bir rehber sunayım.\n\nBu, uygulamayı daha rahat kullanmanız için yardımcı olur."
          }
        }
      }
    },
