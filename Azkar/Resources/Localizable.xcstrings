        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "افتح أذكار الصباح والمساء والنوم وما بعد الصلاة من الشاشة الرئيسية."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
