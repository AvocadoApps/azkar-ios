      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تأثيرات الرسوم المتحركة والكونفيتي وغيرها"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "These are features which make Azkar app a bit beautiful but some people find useless and annoying."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Это функции, которые делают приложение более красочным, но по мнению некоторых людей являются лишними, и они были бы рады их отключить.\nТеперь у таких людей есть своя кнопка. :-)"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu fonksiyon uygulamayı daha renkli yapar, ancak bazı kullanıcılarımız bunun gereksiz olduğunu düşünüyor ve kapatmayı tercih ediyorlar.\nArtık bu kullanıcılarımıza özel düğme ekledik :-)"
          }
        }
      }
    },
