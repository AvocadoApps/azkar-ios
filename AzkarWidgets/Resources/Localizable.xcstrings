    "widget.streak.description" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تتبع سلسلة إنجاز أذكارك اليومية.\nوتذكّر: إنما الأعمال بالنيات."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Track your daily adhkar completion streak.\nAnd remember: deeds are rewarded according to intentions."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Отслеживайте серию ежедневного чтения азкаров.\nИ помните: дела оцениваются по намерениям."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Günlük zikir tamamlama serinizi takip edin.\nVe unutmayın: Ameller niyetlere göredir."
          }
        }
      }
    },
